# Master password hash (bcrypt) — generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
HUB_PASSWORD_HASH=$2b$12$...

# Secret for signing session tokens (min 32 chars)
HUB_SECRET=change_this_to_a_random_secret_at_least_32_chars

# Session duration in hours (default: 8)
HUB_SESSION_HOURS=8

# PostgreSQL — same as nodyx-core
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nexus
DB_USER=nexus
DB_PASSWORD=

# SMTP for newsletter (same as nodyx-core or different)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Hub URL
HUB_ORIGIN=https://olympus.nodyx.org

# Port
PORT=7777
HOST=127.0.0.1
