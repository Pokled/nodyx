    "@tailwindcss/vite": "4.3.3",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "svelte": "^5.56.7",
    "svelte-check": "4.7.3",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vite": "^7.3.6",
