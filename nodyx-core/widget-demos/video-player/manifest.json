{
  "id": "video-player",
  "label": "Lecteur Vidéo",
  "version": "1.1.0",
  "author": "Nodyx",
  "icon": "🎬",
  "family": "media",
  "description": "Lecteur universel : YouTube, Vimeo, Dailymotion, Twitch (live, VOD, clip), SoundCloud, Spotify, ou fichier vidéo direct (MP4, WebM). Colle simplement l'URL.",
  "entry": "widget.iife.js",
  "schema": [
    {
      "key": "url",
      "type": "text",
      "label": "URL",
      "placeholder": "https://youtube.com/watch?v=... ou https://vimeo.com/... ou https://twitch.tv/..."
    },
    {
      "key": "title",
      "type": "text",
      "label": "Titre affiché",
      "placeholder": "Ma vidéo"
    },
    {
      "key": "autoplay",
      "type": "boolean",
      "label": "Lecture automatique"
    },
    {
      "key": "show_controls",
      "type": "boolean",
      "label": "Afficher les contrôles"
    }
  ]
}
